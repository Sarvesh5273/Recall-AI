# ==========================================
# RECALL AI — ENVIRONMENT CONFIGURATION
# ==========================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all required values marked with [REQUIRED]
# 3. Never commit .env to git — it is gitignored
# ==========================================

# ── AZURE STORAGE ──────────────────────────────────────────────────────────────
# Found in: Azure Portal → Storage Account → Security + networking → Access keys
# Format: DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...
AZURE_STORAGE_CONNECTION_STRING=                          # [REQUIRED]
AZURE_STORAGE_CONTAINER_NAME="recall-ledgers"             # [REQUIRED]

# ── AZURE COSMOS DB ─────────────────────────────────────────────────────────────
# Found in: Azure Portal → Cosmos DB → Settings → Keys
COSMOS_DB_ENDPOINT=                                       # [REQUIRED] e.g. https://your-account.documents.azure.com:443/
COSMOS_DB_KEY=                                            # [REQUIRED] Primary key
COSMOS_DB_DATABASE_NAME="recall-db"                       # Default: recall-db
COSMOS_DB_CONTAINER_NAME="recall-container"               # Default: recall-container
COSMOS_DB_TRAINING_CONTAINER_NAME="recall-training"       # Default: recall-training

# ── AZURE OPENAI ────────────────────────────────────────────────────────────────
# Found in: Azure AI Foundry → Deployments → your deployment → Endpoint + Keys
AZURE_OPENAI_ENDPOINT=                                    # [REQUIRED] e.g. https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=                                     # [REQUIRED]
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4o-mini"                # Default: gpt-4o-mini
AZURE_OPENAI_API_VERSION="2024-02-15-preview"             # Default: 2024-02-15-preview

# ── SARVAM AI (Indic OCR) ───────────────────────────────────────────────────────
# Found in: dashboard.sarvam.ai → API Keys
SARVAM_API_KEY=                                           # [REQUIRED]
SARVAM_API_URL="https://api.sarvam.ai/v1/ocr"             # Default: sarvam.ai OCR endpoint

# ── TWILIO (OTP SMS) ────────────────────────────────────────────────────────────
# Found in: console.twilio.com → Account Info
# Note: Trial account can only send to verified numbers
# Note: Indian production SMS requires DLT registration
TWILIO_ACCOUNT_SID=                                       # [REQUIRED]
TWILIO_AUTH_TOKEN=                                        # [REQUIRED]
TWILIO_PHONE_NUMBER=                                      # [REQUIRED] e.g. +1415XXXXXXX

# ── AUTHENTICATION ──────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
# WARNING: Changing this invalidates all existing sessions
JWT_SECRET=                                               # [REQUIRED] min 32 chars

# ── JOB QUEUE (Upstash Redis) ───────────────────────────────────────────────────
# Found in: upstash.com → your database → Details → TCP URL
# Format: rediss://default:password@host:port
# Note: Use TCP endpoint, not REST — required for RQ worker
# Note: Create in AWS ap-south-1 (Mumbai) for lowest latency from Azure India
REDIS_URL=                                                # [REQUIRED]

# ── ADMIN PORTAL ────────────────────────────────────────────────────────────────
# Protects /admin/analytics, /admin/stores, /admin/quarantine-items
# Generate a strong random string: openssl rand -hex 16
# Sent as header: X-Admin-Key: <value>
ADMIN_KEY=                                                # [REQUIRED]

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# Development: http://localhost:8081,http://localhost:5173
# Production: set to your actual deployed domain only
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173